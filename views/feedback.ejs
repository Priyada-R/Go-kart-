<%- include('partials/header') %>

<div class="page-header">
  <h1 class="gradient-text">Share Your Experience</h1>
  <p>We love hearing from our racers! Let us know how your visit went.</p>
</div>

<div class="container">
  <div class="feedback-layout">
    <form class="glass-card feedback-form-inner" id="feedback-form">
      <div class="form-grid" style="margin-bottom: 24px;">
        <div class="form-group">
          <label for="fb-name">Your Name</label>
          <input type="text" id="fb-name" name="name" placeholder="e.g. Bhumika Jadhav" required>
        </div>
        <div class="form-group">
          <label for="fb-email">Email Address</label>
          <input type="email" id="fb-email" name="email" placeholder="pragati@" required>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 24px;">
        <label>How would you rate your experience?</label>
        <div class="star-rating" id="star-rating">
          <span class="star" data-value="1">★</span>
          <span class="star" data-value="2">★</span>
          <span class="star" data-value="3">★</span>
          <span class="star" data-value="4">★</span>
          <span class="star" data-value="5">★</span>
        </div>
        <input type="hidden" id="fb-rating" name="rating" value="0" required>
      </div>

      <div class="form-group" style="margin-bottom: 8px;">
        <label for="fb-message">Your Feedback</label>
        <textarea id="fb-message" name="message" placeholder="Tell us about your experience at Velocity Karting..."
          data-char-limit="500" data-counter="char-count" required></textarea>
      </div>
      <div class="char-counter" id="char-count">0 / 500</div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%; margin-top:24px;">
        Submit Feedback 💬
      </button>
    </form>
  </div>
</div>

<!-- Success Modal -->
<%- include('partials/modal', {
  modalId: 'feedback-success-modal',
  modalIcon: '🙏',
  modalTitle: 'Thank You!',
  modalMessage: 'Your feedback has been submitted successfully. We appreciate your time!',
  modalAction: { href: '/', text: 'Back to Home' }
}) %>

<script src="/js/counter.js"></script>
<script>
  // Star rating interaction
  const stars = document.querySelectorAll('#star-rating .star');
  const ratingInput = document.getElementById('fb-rating');
  let currentRating = 0;

  stars.forEach(star => {
    star.addEventListener('click', () => {
      currentRating = parseInt(star.getAttribute('data-value'));
      ratingInput.value = currentRating;
      updateStars();
    });

    star.addEventListener('mouseenter', () => {
      const val = parseInt(star.getAttribute('data-value'));
      highlightStars(val);
    });
  });

  document.getElementById('star-rating').addEventListener('mouseleave', () => {
    highlightStars(currentRating);
  });

  function highlightStars(count) {
    stars.forEach(s => {
      const val = parseInt(s.getAttribute('data-value'));
      s.classList.toggle('active', val <= count);
    });
  }

  function updateStars() {
    highlightStars(currentRating);
  }

  // Form submit
  document.getElementById('feedback-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    if (currentRating === 0) {
      alert('Please select a rating!');
      return;
    }

    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.success) {
        window.openModal('feedback-success-modal');
        e.target.reset();
        currentRating = 0;
        ratingInput.value = 0;
        updateStars();
        document.getElementById('char-count').textContent = '0 / 500';
      } else {
        alert('Error: ' + result.message);
      }
    } catch (err) {
      alert('Something went wrong. Please try again.');
    }
  });
</script>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="page-header">
  <h1 class="gradient-text">Frequently Asked Questions</h1>
  <p>Got questions? We've got answers. Find everything you need to know about racing at Velocity Karts.</p>
</div>

<div class="container section">
  <div class="faq-list">
    <% faqs.forEach((faq, i) => { %>
      <div class="faq-item animate-on-scroll" style="animation-delay: <%= i * 0.05 %>s">
        <div class="faq-question">
          <span><%= faq.q %></span>
          <span class="faq-icon">+</span>
        </div>
        <div class="faq-answer">
          <div class="faq-answer-inner"><%= faq.a %></div>
        </div>
      </div>
    <% }) %>
  </div>

  <div style="text-align:center; margin-top:60px;">
    <p style="color: var(--text-secondary); margin-bottom:20px;">Still have questions? We're here to help!</p>
    <a href="/feedback" class="btn btn-primary">Contact Us →</a>
  </div>
</div>

<script src="/js/faq.js"></script>

<%- include('partials/footer') %>

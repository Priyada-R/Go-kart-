<%- include('partials/header') %>

<div class="page-header">
  <h1 class="gradient-text">Book Your Race</h1>
  <p>Choose your package, pick a time, and get ready for the ride of your life.</p>
</div>

<div class="container">
  <!-- Packages -->
  <section class="packages-section">
    <h2 class="section-title" style="margin-bottom:40px">Choose Your <span class="accent-text">Package</span></h2>
    <div class="packages-grid" id="packages-container">
      <% packages.forEach((pkg, i) => { %>
        <div class="glass-card package-card <%= i === 1 ? 'featured' : '' %>" data-package="<%= pkg.name %>" data-price="<%= pkg.price %>" onclick="selectPackage(this)">
          <div class="package-name"><%= pkg.name %></div>
          <div class="package-price">
            <span class="currency-symbol">₹</span><span class="price-val"><%= pkg.price %></span>
            <span class="per-person">/person</span>
          </div>
          <div class="package-duration"><%= pkg.duration %> session</div>
          <ul class="package-features">
            <% pkg.features.forEach(f => { %>
              <li><%= f %></li>
            <% }) %>
          </ul>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- Booking Form + Price Summary -->
  <div class="booking-layout">
    <form class="glass-card booking-form" id="booking-form">
      <h3 style="margin-bottom:24px; font-size:1.4rem;">Your Details</h3>
      <div class="form-grid">
        <div class="form-group">
          <label for="book-name">Full Name</label>
          <input type="text" id="book-name" name="name" placeholder="e.g. John Doe" required>
        </div>
        <div class="form-group">
          <label for="book-email">Email</label>
          <input type="email" id="book-email" name="email" placeholder="john@example.com" required>
        </div>
        <div class="form-group">
          <label for="book-phone">Phone</label>
          <input type="tel" id="book-phone" name="phone" placeholder="+1 555 0199" required>
        </div>
        <div class="form-group">
          <label for="book-date">Race Date (Pricing may vary)</label>
          <input type="date" id="book-date" name="date" required>
        </div>
        <div class="form-group">
          <label for="book-time">Time Slot</label>
          <select id="book-time" name="timeSlot" required>
            <option value="">Select a time</option>
            <option value="10:00 AM">10:00 AM</option>
            <option value="11:00 AM">11:00 AM</option>
            <option value="12:00 PM">12:00 PM</option>
            <option value="1:00 PM">1:00 PM</option>
            <option value="2:00 PM">2:00 PM</option>
            <option value="3:00 PM">3:00 PM</option>
            <option value="4:00 PM">4:00 PM</option>
            <option value="5:00 PM">5:00 PM</option>
            <option value="6:00 PM">6:00 PM</option>
            <option value="7:00 PM">7:00 PM</option>
            <option value="8:00 PM">8:00 PM</option>
          </select>
        </div>
        <div class="form-group">
          <label for="book-racers">Number of Racers</label>
          <input type="number" id="book-racers" name="numRacers" min="1" max="20" value="1" required>
        </div>
      </div>
      <input type="hidden" id="book-package" name="packageType" value="">
      <input type="hidden" id="book-currency" name="currency" value="INR">
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%; margin-top:32px;" id="pay-btn">
        Pay & Confirm Booking 🏁
      </button>
    </form>

    <!-- Price Summary Sidebar -->
    <div class="glass-card price-summary">
      <h3>💰 Price Summary</h3>
      <div class="summary-row">
        <span>Package</span>
        <span id="sum-package">—</span>
      </div>
      <div class="summary-row">
        <span>Price / person</span>
        <span id="sum-price">₹0</span>
      </div>
      <div class="summary-row">
        <span>Racers</span>
        <span id="sum-racers">1</span>
      </div>
      <div class="summary-row total">
        <span>Total</span>
        <span id="booking-total" data-total="0">₹0</span>
      </div>

      <!-- Currency Converter -->
      <div class="currency-converter">
        <h4>💱 Currency Converter</h4>
        <div class="currency-select-row">
          <select id="currency-select">
            <option value="INR">🇮🇳 INR</option>
            <option value="EUR">🇪🇺 EUR</option>
            <option value="GBP">🇬🇧 GBP</option>
            <option value="USD">🇺🇸 USD</option>
            <option value="JPY">🇯🇵 JPY</option>
            <option value="AUD">🇦🇺 AUD</option>
            <option value="CAD">🇨🇦 CAD</option>
          </select>
        </div>
        <div id="converted-price" class="converted-price"></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/currency.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const RAZORPAY_KEY = '<%= razorpayKey %>';
  const dateInput = document.getElementById('book-date');
  dateInput.min = new Date().toISOString().split('T')[0];

  let selectedPackage = null;
  let packagePrice = 0;
  
  // Package prices dictionary to decouple DOM from logic
  let prices = {
    Standard: <%= packages[0].price %>,
    Premium: <%= packages[1].price %>,
    VIP: <%= packages[2].price %>
  };

  function selectPackage(card) {
    document.querySelectorAll('.package-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedPackage = card.getAttribute('data-package');
    packagePrice = prices[selectedPackage];
    document.getElementById('book-package').value = selectedPackage;
    updateTotal();
  }

  // Dynamic pricing on date selection
  dateInput.addEventListener('change', async (e) => {
    try {
      const res = await fetch(`/booking/api/price-for-date?date=${e.target.value}`);
      const dynamicPrices = await res.json();
      
      prices = dynamicPrices;
      
      // Update UI Cards
      document.querySelectorAll('.package-card').forEach(card => {
        const pkgName = card.getAttribute('data-package');
        card.setAttribute('data-price', prices[pkgName]);
        card.querySelector('.price-val').textContent = prices[pkgName];
      });
      
      if (selectedPackage) {
        packagePrice = prices[selectedPackage];
        updateTotal();
      }
    } catch(err) {
      console.error("Could not fetch dynamic prices");
    }
  });

  document.getElementById('book-racers').addEventListener('input', updateTotal);

  function updateTotal() {
    if (!selectedPackage) return;
    const racers = parseInt(document.getElementById('book-racers').value) || 1;
    const total = packagePrice * racers;

    document.getElementById('sum-package').textContent = selectedPackage || '—';
    document.getElementById('sum-price').textContent = '₹' + packagePrice;
    document.getElementById('sum-racers').textContent = racers;
    document.getElementById('booking-total').textContent = '₹' + total;
    document.getElementById('booking-total').setAttribute('data-total', total);

    const currencySelect = document.getElementById('currency-select');
    if (currencySelect.value !== 'INR') {
      currencySelect.dispatchEvent(new Event('change'));
    }
  }

  // Form submit -> Razorpay
  document.getElementById('booking-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!selectedPackage) {
      alert('Please select a package first!');
      return;
    }

    const btn = document.getElementById('pay-btn');
    btn.textContent = 'Processing...';
    btn.disabled = true;

    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
      // 1. Create Order
      const res = await fetch('/booking/create-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const order = await res.json();

      if (!order.success) throw new Error(order.message);
      
      // -- Dummy Bypass Flow --
      if (RAZORPAY_KEY === 'dummy_key' || RAZORPAY_KEY.startsWith('YOUR')) {
         alert("Notice: Test keys are used. Simulating successful Razorpay payment automatically.");
         const verifyRes = await fetch('/booking/verify-payment', {
           method: 'POST',
           headers: { 'Content-Type': 'application/json' },
           body: JSON.stringify({
             razorpay_order_id: order.order_id,
             razorpay_payment_id: "pay_dummy_" + Math.random().toString(36).substring(2, 10),
             razorpay_signature: "dummy_sig",
             booking_id: order.booking_id,
             is_dummy: true
           })
         });
         const verifyResult = await verifyRes.json();
         if(verifyResult.success) window.location.href = `/booking/receipt/${verifyResult.receiptId}`;
         else alert("Mock verification failed.");
         return;
      }

      // 2. Initialize Razorpay Checkout
      const options = {
        key: RAZORPAY_KEY,
        amount: order.amount,
        currency: order.currency,
        name: "Velocity Karts",
        description: "Go Karting Session - " + data.packageType,
        order_id: order.order_id,
        handler: async function (response) {
          // 3. Verify Payment
          try {
            const verifyRes = await fetch('/booking/verify-payment', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_order_id: response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature: response.razorpay_signature,
                booking_id: order.booking_id
              })
            });
            
            const verifyResult = await verifyRes.json();
            if (verifyResult.success) {
               // Redirect to Receipt
               window.location.href = `/booking/receipt/${verifyResult.receiptId}`;
            } else {
               alert("Payment verification failed. Please contact support.");
               btn.textContent = 'Pay & Confirm Booking 🏁';
               btn.disabled = false;
            }
          } catch(err) {
             alert('Error verifying payment.');
          }
        },
        prefill: {
          name: data.name,
          email: data.email,
          contact: data.phone
        },
        theme: {
          color: "#ff6a00"
        },
        config: {
          display: {
            blocks: {
              netbanking: {
                name: "Pay via Netbanking",
                instruments: [
                  { method: "netbanking" }
                ]
              },
              upi: {
                name: "Pay via UPI",
                instruments: [
                  { method: "upi" }
                ]
              }
            },
            sequence: ["block.netbanking", "block.upi"],
            preferences: {
              show_default_blocks: false
            }
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function (response){
        alert("Payment failed! Reason: " + response.error.description);
        btn.textContent = 'Pay & Confirm Booking 🏁';
        btn.disabled = false;
      });
      rzp.open();
      
    } catch (err) {
      alert('Error initiating checkout: ' + err.message);
      btn.textContent = 'Pay & Confirm Booking 🏁';
      btn.disabled = false;
    }
  });
</script>

<%- include('partials/footer') %>

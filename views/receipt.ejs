<%- include('partials/header') %>

<main class="page-content" style="padding-top: 120px;">
  <div class="container" style="max-width: 600px; margin: 0 auto;">
    
    <div class="glass-card" style="text-align: center; padding: 40px 20px;">
      <div style="font-size: 4rem; color: #00c853; margin-bottom: 20px;">✅</div>
      <h1 style="margin-bottom: 10px;">Payment Successful!</h1>
      <p style="color: var(--text-secondary); margin-bottom: 30px;">Thank you for your booking, <%= booking.name %>. We can't wait to see you at the track!</p>
      
      <div style="text-align: left; background: rgba(0,0,0,0.3); padding: 20px; border-radius: 8px; margin-bottom: 30px;">
        <h3 style="border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 15px;">Offical Receipt</h3>
        
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
          <span style="color: var(--text-secondary);">Receipt ID:</span>
          <strong><%= booking.receiptId %></strong>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
          <span style="color: var(--text-secondary);">Razorpay ID:</span>
          <strong><small><%= booking.razorpayPaymentId %></small></strong>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
          <span style="color: var(--text-secondary);">Date & Time:</span>
          <strong><%= new Date(booking.date).toLocaleDateString() %> at <%= booking.timeSlot %></strong>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
          <span style="color: var(--text-secondary);">Package:</span>
          <strong style="color: var(--primary);"><%= booking.packageType %></strong>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
          <span style="color: var(--text-secondary);">Number of Racers:</span>
          <strong><%= booking.numRacers %></strong>
        </div>
        <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.1); margin: 15px 0;">
        <div style="display: flex; justify-content: space-between; font-size: 1.2rem;">
          <span>Total Amount Paid:</span>
          <strong style="color: #00c853;">₹<%= booking.totalPrice %></strong>
        </div>
      </div>
      
      <button onclick="window.print()" class="btn btn-outline" style="margin-right: 10px;">🖨️ Print Receipt</button>
      <a href="/" class="btn btn-primary">Return Home</a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<%- include('../partials/admin-header') %>

<main style="flex: 1; display: flex; justify-content: center; align-items: center; padding: 120px 20px 40px 20px; background: radial-gradient(circle at center, rgba(234,0,0,0.1) 0%, transparent 60%);">
  <div class="glass-card" style="max-width: 420px; width: 100%; padding: 40px 30px; text-align: center; border: 1px solid rgba(234,0,0,0.3); box-shadow: 0 10px 40px rgba(0,0,0,0.5), 0 0 40px rgba(234,0,0,0.1);">
    
    <div style="font-size: 3rem; margin-bottom: 10px;">🛡️</div>
    <h1 style="color: var(--primary); margin-bottom: 5px; font-size: 2rem;">Admin Portal</h1>
    <p style="color: var(--text-secondary); margin-bottom: 30px; font-size: 0.9rem;">Authorized Personnel Only</p>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: rgba(255, 50, 50, 0.2); color: #ff5555; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; border: 1px solid rgba(255,50,50,0.3);">
        ⚠️ <%= error %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST" style="text-align: left;">
      <div class="form-group" style="margin-bottom: 20px;">
        <label for="username" style="font-weight: bold; color: #ddd;">👤 Username</label>
        <input type="text" id="username" name="username" class="form-control" style="background: rgba(0,0,0,0.6); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px; padding: 12px;" required placeholder="Enter admin username">
      </div>
      <div class="form-group" style="margin-bottom: 25px;">
        <label for="password" style="font-weight: bold; color: #ddd;">🔑 Password</label>
        <input type="password" id="password" name="password" class="form-control" style="background: rgba(0,0,0,0.6); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px; padding: 12px;" required placeholder="Enter super secret password">
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; border-radius: 8px; letter-spacing: 1px; font-weight: bold; box-shadow: 0 0 15px rgba(234,0,0,0.4);">
        Authenticate & Enter
      </button>
    </form>
  </div>
</main>

<%- include('../partials/admin-footer') %>
